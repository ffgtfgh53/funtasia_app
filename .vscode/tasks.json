{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Funtasia Servers",
      "dependsOn": [
        "Serve App",
        "Tailscale Funnel"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Serve App",
      "type": "shell",
      "command": "npx serve -l 3000",
      "isBackground": true,
      "presentation": {
        "group": "funtasia-servers",
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      }
    },
    {
      "label": "Tailscale Funnel",
      "type": "shell",
      "command": "tailscale funnel 3000",
      "isBackground": true,
      "presentation": {
        "group": "funtasia-servers",
        "panel": "shared",
        "showReuseMessage": false,
        "clear": true
      }
    }
  ]
}
